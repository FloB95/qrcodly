{
	"name": "@apps/mcp-server",
	"version": "0.1.0",
	"description": "Remote MCP server for the QRcodly API",
	"main": "src/index.ts",
	"type": "module",
	"private": true,
	"author": "Florian Breuer",
	"license": "MIT",
	"engines": {
		"node": ">=22.11.0"
	},
	"scripts": {
		"lint": "eslint .",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"pr:precheck": "pnpm run lint && pnpm run typecheck && pnpm run build",
		"build": "tsc -p tsconfig.json",
		"start": "node build/index.js",
		"dev": "tsx watch src/index.ts",
		"update-openapi": "curl -s -o src/openapi.json https://api.qrcodly.de/api/v1/openapi.json"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@fastify/cors": "^11.0.0",
		"fastify": "^5.3.3"
	},
	"devDependencies": {
		"@types/node": "^22.19.9",
		"@typescript-eslint/eslint-plugin": "^8.48.1",
		"@typescript-eslint/parser": "^8.48.1",
		"qrcodly-eslint-config": "workspace:*",
		"qrcodly-typescript-config": "workspace:*",
		"tsx": "^4.20.3",
		"typescript": "catalog:"
	}
}
