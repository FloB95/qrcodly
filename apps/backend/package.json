{
	"name": "@apps/backend",
	"version": "1.0.0",
	"description": "QRcodly Backend App",
	"main": "src/index.ts",
	"type": "module",
	"private": true,
	"keywords": [],
	"author": "Florian Breuer",
	"license": "ISC",
	"engines": {
		"node": ">=22.11.0"
	},
	"scripts": {
		"lint": "eslint .",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"pr:precheck": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
		"build": "tsc -p tsconfig.json && tsc-alias && tsc-esm-fix && node build/src/core/config/env.js && pnpm run copyMailerTemplates",
		"copyMailerTemplates": "cp -r ./src/core/mailer/templates ./build/src/core/mailer/templates",
		"start": "pnpm run db:migrate && TZ=Europe/Berlin node build/src/index.js",
		"dev-server": "docker-compose up -d",
		"dev": "pnpm run db:migrate && TZ=Europe/Berlin tsx watch --include ./src src/index.ts",
		"test": "export NODE_ENV=test && export LOG_LEVEL=error && export FRONTEND_URL=https://test.qrcodly.de && pnpm run db:migrate && jest --runInBand",
		"test:coverage": "export NODE_ENV=test && export LOG_LEVEL=error && export FRONTEND_URL=https://test.qrcodly.de && pnpm run db:migrate && jest --runInBand --coverage",
		"test:detectOpenHandles": "jest --silent --runInBand --detectOpenHandles",
		"db:push": "drizzle-kit push --config=drizzle.config.ts",
		"db:migrate": "DB_MIGRATING=true tsx src/core/db/migrate.ts",
		"db:generate-migration": "drizzle-kit generate --config=drizzle.config.ts",
		"studio": "drizzle-kit studio",
		"cli:list": "npx tsx src/cli.ts list",
		"script:find-orphaned-urls": "SKIP_ENV_VALIDATION=true tsx scripts/find-orphaned-short-urls.ts",
		"script:test-smtp": "tsx scripts/test-smtp.ts",
		"script:regenerate-previews": "SKIP_ENV_VALIDATION=true tsx scripts/regenerate-preview-images.ts"
	},
	"devDependencies": {
		"@aws-sdk/types": "^3.973.6",
		"@faker-js/faker": "^9.9.0",
		"@types/jest": "^30.0.0",
		"@types/jsdom": "^28.0.1",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node-cron": "^3.0.11",
		"@types/nodemailer": "^7.0.11",
		"@types/qs": "^6.15.0",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
		"drizzle-kit": "^0.31.10",
		"esbuild": "~0.27.4",
		"eslint-plugin-drizzle": "^0.2.3",
		"form-data": "^4.0.5",
		"get-tsconfig": "^4.13.7",
		"jest-mock-extended": "4.0.0",
		"qrcodly-eslint-config": "workspace:*",
		"qrcodly-typescript-config": "workspace:*",
		"ts-jest": "^29.4.6",
		"ts-jest-mock-import-meta": "^1.3.1",
		"tsc-alias": "^1.8.16",
		"tsc-esm-fix": "^3.1.2",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1017.0",
		"@aws-sdk/s3-request-presigner": "^3.1017.0",
		"@axiomhq/pino": "^1.5.0",
		"@clerk/fastify": "^2.6.17",
		"@fastify/cookie": "^11.0.2",
		"@fastify/cors": "^11.1.0",
		"@fastify/csrf-protection": "^7.1.0",
		"@fastify/helmet": "^13.0.2",
		"@fastify/multipart": "^9.4.0",
		"@fastify/otel": "^0.18.0",
		"@fastify/rate-limit": "^10.3.0",
		"@fastify/swagger": "^9.7.0",
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/exporter-metrics-otlp-proto": "^0.214.0",
		"@opentelemetry/exporter-trace-otlp-proto": "^0.214.0",
		"@opentelemetry/host-metrics": "^0.38.3",
		"@opentelemetry/instrumentation-http": "^0.214.0",
		"@opentelemetry/resources": "^2.6.1",
		"@opentelemetry/sdk-metrics": "^2.6.1",
		"@opentelemetry/sdk-node": "^0.214.0",
		"@opentelemetry/semantic-conventions": "^1.40.0",
		"@sentry/node": "catalog:",
		"@shared/schemas": "workspace:^",
		"commander": "^14.0.3",
		"csv-parse": "^6.2.1",
		"dotenv": "catalog:",
		"drizzle-orm": "^0.45.1",
		"drizzle-zod": "^0.8.3",
		"fastify": "^5.8.4",
		"handlebars": "^4.7.8",
		"ioredis": "^5.10.1",
		"jsdom": "^26.1.0",
		"jsonwebtoken": "^9.0.3",
		"mysql2": "^3.20.0",
		"node-cron": "^4.2.1",
		"nodemailer": "^8.0.4",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"qr-code-styling": "^1.9.2",
		"qs": "^6.15.0",
		"reflect-metadata": "^0.2.2",
		"stripe": "^21.0.0",
		"svix": "^1.89.0",
		"tsyringe": "^4.10.0",
		"uuid": "^11.1.0",
		"zod": "catalog:",
		"zod-to-json-schema": "^3.25.1",
		"zod-validation-error": "^5.0.0"
	}
}
